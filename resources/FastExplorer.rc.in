#include <winres.h>
#include "@CMAKE_CURRENT_SOURCE_DIR@/resources/resource-ids.h"

// CREATEPROCESS_MANIFEST_RESOURCE_ID (1) is required for asInvoker manifests.
1 24 "@CMAKE_CURRENT_SOURCE_DIR@/resources/FastExplorer.exe.manifest"

IDI_APP ICON "@CMAKE_CURRENT_SOURCE_DIR@/resources/fast_explorer_icon.ico"

// Lucide icon font (ISC license, see third_party/lucide/LICENSE).
// Loaded at runtime via AddFontMemResourceEx; family name "lucide".
IDR_LUCIDE_FONT RCDATA "@CMAKE_CURRENT_SOURCE_DIR@/third_party/lucide/lucide.ttf"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @FastExplorer_VERSION_MAJOR@,@FastExplorer_VERSION_MINOR@,@FastExplorer_VERSION_PATCH@,0
 PRODUCTVERSION @FastExplorer_VERSION_MAJOR@,@FastExplorer_VERSION_MINOR@,@FastExplorer_VERSION_PATCH@,0
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
 FILEFLAGS      0
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Fast Explorer Project"
            VALUE "FileDescription",  "Fast Explorer"
            VALUE "FileVersion",      "@FastExplorer_VERSION_MAJOR@.@FastExplorer_VERSION_MINOR@.@FastExplorer_VERSION_PATCH@.0"
            VALUE "InternalName",     "FastExplorer"
            VALUE "OriginalFilename", "FastExplorer.exe"
            VALUE "ProductName",      "Fast Explorer"
            VALUE "ProductVersion",   "@FastExplorer_VERSION_MAJOR@.@FastExplorer_VERSION_MINOR@.@FastExplorer_VERSION_PATCH@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
